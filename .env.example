# App Configuration
APP_NAME="Real Estate API"
APP_ENV=development
DEBUG=true
API_V1_STR="/api/v1"
HOST=0.0.0.0
PORT=8000

# Security & JWT
# Run openssl rand -hex 32 to generate secret keys
JWT_SECRET_KEY="super-secret-key-change-in-production"
JWT_REFRESH_SECRET_KEY="super-refresh-secret-key-change-in-production"
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# Database Settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=real_estate
DATABASE_URL="postgresql+asyncpg://postgres:postgres@postgres:5432/real_estate"

# pgAdmin Settings
PGADMIN_DEFAULT_EMAIL="admin@realestate.com"
PGADMIN_DEFAULT_PASSWORD="admin"

# CORS Settings
CORS_ORIGINS='["http://localhost:3000", "http://localhost:8000"]'

# Image Uploads Settings
UPLOAD_DIR="app/static/uploads"
MAX_FILE_SIZE=5242880 # 5MB in bytes
ALLOWED_IMAGE_EXTENSIONS='["jpg", "jpeg", "png", "webp"]'

# Initial Admin User Credentials
INIT_ADMIN_EMAIL="admin@realestate.com"
INIT_ADMIN_PASSWORD="AdminPassword123!"
